{
  "expo": {
    "name": "Heart",
    "slug": "heart-rate-monitor",
    "version": "1.0.0",
    "orientation": "portrait",
    "backgroundColor": "#0a0a0f",
    "ios": {
      "bundleIdentifier": "com.jess.heartratemonitor",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "This app needs Bluetooth to connect to your heart rate sensor.",
        "NSBluetoothPeripheralUsageDescription": "This app needs Bluetooth to connect to your heart rate sensor.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.jess.heartratemonitor",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "plugins": [
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "Allow $(PRODUCT_NAME) to connect to Bluetooth devices"
        }
      ]
    ]
  }
}
